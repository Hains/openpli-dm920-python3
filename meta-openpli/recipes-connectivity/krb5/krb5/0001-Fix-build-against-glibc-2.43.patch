From: Hains van den Bosch <hainsvdbosch@ziggo.nl>
Date: Sat, 14 Mar 2026 11:51:31 +0100
Subject: [PATCH] Fix build against glibc 2.43

https://lists.gnu.org/archive/html/info-gnu/2026-01/msg00005.html

| locate_kdc.c: In function 'parse_uri_if_https':
| locate_kdc.c:226:12: error: assignment discards 'const' qualifier from pointer target type [-Werror=discarded-qualifiers]
|   226 |         cp = strchr(*host, '/');
|       |
---
 src/lib/krb5/ccache/ccbase.c                       | 4 ++--
 src/lib/krb5/os/expand_path.c                      | 4 ++--
 src/lib/krb5/os/locate_kdc.c                       | 2 +-
 src/plugins/preauth/pkinit/pkinit_crypto.h         | 2 +-
 src/plugins/preauth/pkinit/pkinit_crypto_openssl.c | 6 +++---
 src/plugins/preauth/pkinit/pkinit_identity.c       | 2 +-
 src/plugins/preauth/pkinit/pkinit_matching.c       | 2 +-
 7 files changed, 11 insertions(+), 11 deletions(-)

diff --git a/src/lib/krb5/ccache/ccbase.c b/src/lib/krb5/ccache/ccbase.c
index 696b681..9fc7d10 100644
--- a/src/lib/krb5/ccache/ccbase.c
+++ b/src/lib/krb5/ccache/ccbase.c
@@ -201,8 +201,8 @@ krb5_cc_register(krb5_context context, const krb5_cc_ops *ops,
 krb5_error_code KRB5_CALLCONV
 krb5_cc_resolve (krb5_context context, const char *name, krb5_ccache *cache)
 {
-    char *pfx, *cp;
-    const char *resid;
+    char *pfx;
+    const char *resid, *cp;
     unsigned int pfxlen;
     krb5_error_code err;
     const krb5_cc_ops *ops;
diff --git a/src/lib/krb5/os/expand_path.c b/src/lib/krb5/os/expand_path.c
index 5cbccf0..51bc266 100644
--- a/src/lib/krb5/os/expand_path.c
+++ b/src/lib/krb5/os/expand_path.c
@@ -454,8 +454,8 @@ k5_expand_path_tokens_extra(krb5_context context, const char *path_in,
 {
     krb5_error_code ret;
     struct k5buf buf;
-    char *tok_begin, *tok_end, *tok_val, **extra_tokens = NULL, *path;
-    const char *path_left;
+    char *tok_val, **extra_tokens = NULL, *path;
+    const char *path_left, *tok_begin, *tok_end;
     size_t nargs = 0, i;
     va_list ap;
 
diff --git a/src/lib/krb5/os/locate_kdc.c b/src/lib/krb5/os/locate_kdc.c
index d1df04a..fa04333 100644
--- a/src/lib/krb5/os/locate_kdc.c
+++ b/src/lib/krb5/os/locate_kdc.c
@@ -223,7 +223,7 @@ parse_uri_if_https(const char *host_or_uri, k5_transport *transport,
         *transport = HTTPS;
         *host = host_or_uri + 8;
 
-        cp = strchr(*host, '/');
+        cp = (char*)strchr(*host, '/');
         if (cp != NULL) {
             *cp = '\0';
             *uri_path = cp + 1;
diff --git a/src/plugins/preauth/pkinit/pkinit_crypto.h b/src/plugins/preauth/pkinit/pkinit_crypto.h
index 57bb3cb..f6b6a59 100644
--- a/src/plugins/preauth/pkinit/pkinit_crypto.h
+++ b/src/plugins/preauth/pkinit/pkinit_crypto.h
@@ -440,7 +440,7 @@ krb5_error_code crypto_load_cas_and_crls
 		    defines the storage type (file, directory, etc) */
 	int catype,					/* IN
 		    defines the ca type (anchor, intermediate, crls) */
-	char *id);					/* IN
+	const char *id);					/* IN
 		    defines the location (filename, directory name, etc) */
 
 /*
