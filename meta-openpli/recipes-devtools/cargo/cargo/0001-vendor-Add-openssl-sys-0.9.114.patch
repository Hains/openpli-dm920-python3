+fn env(name: &str) -> Option<OsString> {
+    let prefix = env::var("TARGET").unwrap().to_uppercase().replace('-', "_");
+    let prefixed = format!("{prefix}_{name}");
+    env_inner(&prefixed).or_else(|| env_inner(name))
