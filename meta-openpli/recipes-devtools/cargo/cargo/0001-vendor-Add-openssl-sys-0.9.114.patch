+        .enable_function_attribute_detection()
+        .default_macro_constant_type(MacroTypeVariation::Signed)
+        .rustified_enum("point_conversion_form_t")
+        .allowlist_file(".*[/\\\\]openssl/[^/]+\\.h")
+        .allowlist_recursively(false)
