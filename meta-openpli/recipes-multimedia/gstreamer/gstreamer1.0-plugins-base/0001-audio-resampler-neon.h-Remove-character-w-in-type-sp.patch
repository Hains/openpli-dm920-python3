From f1ab44f3bba32ce600545a42f756c382072111ad Mon Sep 17 00:00:00 2001
From: Hains van den Bosch <hainsvdbosch@ziggo.nl>
Date: Tue, 26 May 2026 18:07:45 +0200
Subject: [PATCH] audio-resampler-neon.h: Remove character `w' in type
 specifier

Partly reverts commit:
https://github.com/GStreamer/gstreamer/commit/f63563877786cedf3e31a02b6f478fdc6103a3c4

Fix:

resampler.c.o -c ../sources/gst-plugins-base-1.28.3/gst-libs/gst/audio/audio-resampler.c
| Assembler messages:
| {standard input}:1456: Error: unexpected character `w' in type specifier
| {standard input}:1456: Error: bad instruction `add.w r8,r8,ip'
| {standard input}:1458: Error: unexpected character `w' in type specifier
| {standard input}:1458: Error: bad instruction `add.w r8,r8,ip'
---
 .../gst-libs/gst/audio/audio-resampler-neon.h | 34 +++++++++----------
 1 file changed, 17 insertions(+), 17 deletions(-)

diff --git a/gst-libs/gst/audio/audio-resampler-neon.h b/gst-libs/gst/audio/audio-resampler-neon.h
index da53469d7d..5edddf745e 100644
--- a/gst-libs/gst/audio/audio-resampler-neon.h
+++ b/gst-libs/gst/audio/audio-resampler-neon.h
@@ -133,11 +133,11 @@ inner_product_gint16_cubic_1_neon (gint16 * o, const gint16 * a,
                   "1:"
                   "      mov r8, %[b]\n"
                   "      vld1.16 {d16, d17}, [%[b]]!\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.16 {d18, d19}, [r8]\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.16 {d20, d21}, [r8]\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.16 {d22, d23}, [r8]\n"
                   "      vld1.16 {d24, d25}, [%[a]]!\n"
                   "      subs %[len], %[len], #8\n"
@@ -214,11 +214,11 @@ interpolate_gint16_cubic_neon (gpointer op, const gpointer ap,
                   "1:"
                   "      mov r8, %[a]\n"
                   "      vld1.16 {d16, d17}, [%[a]]!\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.16 {d18, d19}, [r8]\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.16 {d20, d21}, [r8]\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.16 {d22, d23}, [r8]\n"
                   "      subs %[len], %[len], #8\n"
                   "      vmull.s16 q0, d16, d24\n"
@@ -340,11 +340,11 @@ inner_product_gint32_cubic_1_neon (gint32 * o, const gint32 * a,
                   "1:"
                   "      mov r8, %[b]\n"
                   "      vld1.32 {d16, d17}, [%[b]]!\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.32 {d18, d19}, [r8]\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.32 {d20, d21}, [r8]\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.32 {d22, d23}, [r8]\n"
                   "      vld1.32 {d24, d25}, [%[a]]!\n"
                   "      subs %[len], %[len], #4\n"
@@ -426,11 +426,11 @@ interpolate_gint32_cubic_neon (gpointer op, const gpointer ap,
                   "1:"
                   "      mov r8, %[a]\n"
                   "      vld1.32 {d16, d17}, [%[a]]!\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.32 {d18, d19}, [r8]\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.32 {d20, d21}, [r8]\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.32 {d22, d23}, [r8]\n"
                   "      subs %[len], %[len], #4\n"
                   "      vmull.s32 q0, d16, d24\n"
@@ -545,11 +545,11 @@ inner_product_gfloat_cubic_1_neon (gfloat * o, const gfloat * a,
                   "1:"
                   "      mov r8, %[b]\n"
                   "      vld1.32 {q8}, [%[b]]!\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.32 {q9}, [r8]\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.32 {q10}, [r8]\n"
-                  "      add.w r8, r8, %[bstride]\n"
+                  "      add r8, r8, %[bstride]\n"
                   "      vld1.32 {q11}, [r8]\n"
                   "      vld1.32 {q12}, [%[a]]!\n"
                   "      subs %[len], %[len], #4\n"
@@ -623,11 +623,11 @@ interpolate_gfloat_cubic_neon (gpointer op, const gpointer ap,
                   "1:"
                   "      mov r8, %[a]\n"
                   "      vld1.32 {q8}, [%[a]]!\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.32 {q9}, [r8]\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.32 {q10}, [r8]\n"
-                  "      add.w r8, r8, %[astride]\n"
+                  "      add r8, r8, %[astride]\n"
                   "      vld1.32 {q11}, [r8]\n"
                   "      subs %[len], %[len], #4\n"
                   "      vmul.f32 q0, q8, q12\n"
-- 
